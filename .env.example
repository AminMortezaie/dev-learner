DATABASE_URL=postgres://devlearn:devlearn@localhost:5432/devlearn
PORT=5000

# AI provider (OpenAI-compatible). Supports Cerebras, OpenAI, Groq, Ollama, etc.
# When unset, quiz/article generation uses a deterministic fallback.
#
# Cerebras (recommended): https://cloud.cerebras.ai
#   AI_BASE_URL=https://api.cerebras.ai/v1
#   AI_MODEL=gpt-oss-120b
#
# Groq (free tier): https://console.groq.com
#   AI_BASE_URL=https://api.groq.com/openai/v1
#   AI_MODEL=llama-3.3-70b-versatile
#
# OpenAI:
#   AI_BASE_URL=https://api.openai.com/v1
#   AI_MODEL=gpt-4o-mini
#
# Ollama (local):
#   AI_BASE_URL=http://localhost:11434/v1
#   AI_MODEL=llama3.2
AI_BASE_URL=https://api.cerebras.ai/v1
AI_API_KEY=
AI_MODEL=gpt-oss-120b

# Token limits (lower = fewer rate-limit errors; raise if quality drops)
# AI_QUIZ_ARTICLE_CHARS=3000
# AI_QUIZ_DEFAULT_COUNT=5
# AI_QUIZ_MAX_OUTPUT_TOKENS=2048
# AI_POLISH_CHUNK_CHARS=10000
# AI_POLISH_MAX_OUTPUT_TOKENS=2048
